generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String @id @default(cuid())
  name         String @unique
  rankedEvents String @default("[]")
}

model Event {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
}