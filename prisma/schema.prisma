generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String @id @default(cuid())
  name          String @unique
  rankedEvents  String @default("[]")
  skippedEvents String @default("[]")
  coins         Int    @default(0)
  character     String @default("blob")
  equipped      String @default("[]")
  purchased     String @default("[]")
}

model Event {
  id          String    @id @default(cuid())
  name        String
  location    String?
  description String?
  date        DateTime?
  category    String?
  createdAt   DateTime  @default(now())
}